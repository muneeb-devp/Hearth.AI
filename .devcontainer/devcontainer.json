{
  "name": "Hearth.AI Dev",
  "image": "mcr.microsoft.com/devcontainers/dotnet:1-9.0",
  "features": {
    "ghcr.io/devcontainers/features/dotnet:2": {
      "version": "9.0"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-dotnettools.csdevkit",
        "humao.rest-client",
        "ms-dotnettools.vscode-dotnet-runtime"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "dotnet.defaultSolution": "Hearth.slnx"
      }
    }
  },
  "postCreateCommand": "dotnet restore && dotnet tool restore",
  "forwardPorts": [5000, 5001],
  "portsAttributes": {
    "5000": {
      "label": "Hearth API (HTTP)",
      "onAutoForward": "notify"
    },
    "5001": {
      "label": "Hearth API (HTTPS)",
      "onAutoForward": "notify"
    }
  },
  "remoteEnv": {
    "HEARTH_MODEL": "/workspaces/Hearth.AI/models/model.gguf"
  }
}
