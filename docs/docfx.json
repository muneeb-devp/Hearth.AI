{
  "metadata": [
    {
      "src": [
        {
          "src": "..",
          "files": [
            "src/Hearth/Hearth.csproj",
            "src/Hearth.AspNetCore/Hearth.AspNetCore.csproj",
            "src/Hearth.Cuda/Hearth.Cuda.csproj",
            "src/Hearth.Metal/Hearth.Metal.csproj",
            "src/Hearth.Vulkan/Hearth.Vulkan.csproj"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "index.md",
          "toc.yml",
          "api/**.yml",
          "api/index.md",
          "articles/**.md",
          "articles/**/toc.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          ".nojekyll"
        ]
      }
    ],
    "dest": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appTitle": "Hearth Documentation",
      "_appName": "Hearth",
      "_appFooter": "Hearth",
      "_enableSearch": true
    }
  }
}
